VITE_APP_BASE_PATH=/
# Optional: local kernel-api (default PORT 8087). Same value is used for JSON + STL in the demo.
# VITE_KERNEL_API_BASE_URL=http://127.0.0.1:8087
# Session token for the SDK provider (CadbuildrProvider). Required unless your
# kernel-api runs in open mode (no CLOUD_AGENT_API_TOKEN set). A local open-mode
# kernel-api accepts any well-formed cbv1.* string, so this placeholder works for
# local dev; in production pass a real hub-minted cbv1.* token (or use a keyId
# browser flow). Without it, CadbuildrProvider throws and the canvas stays blank.
# VITE_CADBUILDR_SESSION_TOKEN=cbv1.dev-placeholder.sig
# Publishable keyId for the keyId browser flow (the deployed GitHub Pages path).
# When no session token is set, the provider mints a short-lived cbv1 token from
# the hub using this key (origin-locked, no secret in the bundle). Defaults to
# the shared cadbuildr.github.io demo key; override with a project-dedicated key.
# VITE_CADBUILDR_SDK_KEY_ID=535336cb21b42a3a
# Optional: override the hub used to mint keyId tokens (default https://hub.cadbuildr.com).
# VITE_CADBUILDR_HUB_BASE_URL=
VITE_FOUNDATION_IMPORT_PATH=cadbuildr.foundation
VITE_FOUNDATION_PACKAGE_NAME=cadbuildr-foundation
VITE_FOUNDATION_VERSION=^0.2.0
VITE_PCB_IMPORT_PATH=cadbuildr.electronics
# Optional: PyPI-style requirement (not used by default; PCB loads from repo wheel)
# VITE_PCB_PACKAGE_REQUIREMENT=
# Optional: override wheel URL (default: same-origin local-pcb/*.whl — dev serves ../dist via Vite; prod copy wheel into public/local-pcb/)
# VITE_PCB_PACKAGE_WHEEL_URL=
